---
import Base from "../layouts/Base.astro";
---
<Base title="Not found" description="That page doesn't exist.">
  <div class="py-16 text-center">
    <p class="font-data text-6xl font-bold text-active">404</p>
    <h1 class="mt-4 text-2xl font-semibold text-text-primary">Page not found</h1>
    <p class="mt-2 text-text-muted">
      The page you're looking for doesn't exist.
    </p>
    <a
      href="/"
      class="mt-6 inline-block rounded-md bg-active px-4 py-2 text-sm font-medium text-ink hover:bg-amber-500/90"
    >
      Back to topics
    </a>
  </div>
</Base>
