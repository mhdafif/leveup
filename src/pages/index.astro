---
import Base from "../layouts/Base.astro";
import CalendarDashboard from "../components/CalendarDashboard.svelte";
import TopicAccordion from "../components/TopicAccordion.svelte";
import UserTopics from "../components/UserTopics.svelte";
import { getTopics } from "../lib/content";

const topics = await getTopics();
---
<Base>
  <h1 class="text-2xl font-semibold text-text-primary">Topics</h1>
  <p class="mt-1 text-text-muted">
    Pick a topic to study. Your progress is tracked automatically.
  </p>

  <div class="mt-5">
    <CalendarDashboard client:load />
  </div>

  <h2 class="mt-8 mb-3 font-data text-xs font-semibold tracking-widest text-text-muted uppercase">
    Built-in topics
  </h2>
  <TopicAccordion topics={topics} client:load />

  <UserTopics client:load />
</Base>
