---
import Base from "../layouts/Base.astro";
import ReviewQueue from "../components/ReviewQueue.svelte";
---
<Base title="Review" description="Review due lessons and keep knowledge fresh.">
  <h1 class="text-2xl font-semibold text-text-primary">Review mode</h1>
  <p class="mt-1 text-text-muted">
    Revisit completed lessons. Pick how it felt, then LevelUp schedules the next review.
  </p>
  <div class="mt-6">
    <ReviewQueue client:load />
  </div>
</Base>
