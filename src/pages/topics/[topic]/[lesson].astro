---
import { getCollection, render } from "astro:content";
import Base from "../../../layouts/Base.astro";
import Mermaid from "../../../components/Mermaid.svelte";
import Checklist from "../../../components/Checklist.svelte";
import Notes from "../../../components/Notes.svelte";
import RoadmapLinks from "../../../components/RoadmapLinks.svelte";
import DifficultySwitch from "../../../components/DifficultySwitch.svelte";
import LessonVariant from "../../../components/LessonVariant.svelte";
import AbbrEnhancer from "../../../components/AbbrEnhancer.svelte";

export async function getStaticPaths() {
  const lessons = await getCollection("lessons");
  return lessons.map((entry) => {
    const [topic, lesson] = entry.id.split("/");
    return { params: { topic, lesson }, props: { entry } };
  });
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const [topicSlug, lessonSlug] = entry.id.split("/");
const { checklist } = entry.data;

// Optional authored beginner variant (NN-slug.easy.md), matched by shared id.
const easyEntries = await getCollection("lessonsEasy");
const easyEntry = easyEntries.find((e) => e.id === entry.id);
const EasyContent = easyEntry ? (await render(easyEntry)).Content : null;
---
<Base title={entry.data.title}>
  <div class="flex flex-wrap items-center justify-between gap-3">
    <a href={`/topics/${topicSlug}`} class="text-sm font-medium text-active hover:underline">
      ← Back to topic
    </a>
    <DifficultySwitch hasEasy={!!EasyContent} client:load />
  </div>
  <div class="mt-4 grid gap-8 lg:grid-cols-[1fr_20rem]">
    <div>
      <article
        class="prose prose-invert max-w-none"
        data-variant="expert"
        data-lesson-body
        data-pagefind-body
        data-pagefind-meta={`topic:${topicSlug}`}
      >
        <h1 class="mb-2">{entry.data.title}</h1>
        <Content />
      </article>
      {EasyContent && (
        <article class="prose prose-invert max-w-none" data-variant="easy" data-lesson-body hidden>
          <h1 class="mb-2">{entry.data.title}</h1>
          <EasyContent />
        </article>
      )}
    </div>
    <aside class="flex flex-col gap-4 lg:sticky lg:top-24 lg:self-start">
      {checklist.length > 0 && (
        <Checklist
          topic={topicSlug}
          lesson={lessonSlug}
          items={checklist}
          client:load
        />
      )}
      <Notes topic={topicSlug} lesson={lessonSlug} client:load />
    </aside>
  </div>
  <Mermaid client:idle />
  <LessonVariant hasEasy={!!EasyContent} client:load />
  <AbbrEnhancer client:load />
  {topicSlug === "frontend-path" && <RoadmapLinks client:load />}
</Base>
