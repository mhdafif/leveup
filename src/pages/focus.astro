---
import Base from "../layouts/Base.astro";
import FocusTimer from "../components/FocusTimer.svelte";
---
<Base title="Focus" description="Run focused study sessions and earn coins.">
  <h1 class="text-2xl font-semibold text-text-primary">Focus timer</h1>
  <p class="mt-1 text-text-muted">
    Complete focused sessions. Every full 5 minutes gives 1 coin and 1 XP.
  </p>
  <div class="mt-6">
    <FocusTimer client:load />
  </div>
</Base>
